<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d1b3e"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:background="#1a2340">
        <Button android:id="@+id/btnMenu" android:layout_width="40dp" android:layout_height="40dp" android:text="☰" android:background="#363d52" android:textColor="#e8eaf0"/>
        <TextView android:id="@+id/tvTitulo" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Gestor360°" android:textColor="#4dd0c4" android:textSize="20sp" android:textStyle="bold" android:layout_marginStart="12dp"/>
        <TextView android:id="@+id/tvUsuario" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="admin" android:textColor="#5a6278" android:textSize="14sp"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/sidebar" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#1a2340" android:padding="8dp" android:visibility="gone">
        <Button android:id="@+id/menuDashboard" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Dashboard" android:background="#0d1b3e" android:textColor="#e8eaf0" android:gravity="start" android:padding="12dp"/>
        <Button android:id="@+id/menuVentas" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Ventas" android:background="#0d1b3e" android:textColor="#e8eaf0" android:gravity="start" android:padding="12dp"/>
        <Button android:id="@+id/menuProductos" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Productos" android:background="#0d1b3e" android:textColor="#e8eaf0" android:gravity="start" android:padding="12dp"/>
        <Button android:id="@+id/menuInventario" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Inventario" android:background="#0d1b3e" android:textColor="#e8eaf0" android:gravity="start" android:padding="12dp"/>
        <Button android:id="@+id/menuContador" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Contador" android:background="#0d1b3e" android:textColor="#e8eaf0" android:gravity="start" android:padding="12dp"/>
        <Button android:id="@+id/menuStockReal" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Stock Real" android:background="#0d1b3e" android:textColor="#e8eaf0" android:gravity="start" android:padding="12dp"/>
        <Button android:id="@+id/menuChat" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Chat" android:background="#0d1b3e" android:textColor="#e8eaf0" android:gravity="start" android:padding="12dp"/>
        <Button android:id="@+id/menuLogout" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Cerrar Sesión" android:background="#0d1b3e" android:textColor="#ff6b6b" android:gravity="start" android:padding="12dp"/>
    </LinearLayout>

    <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:padding="16dp">
        <LinearLayout android:id="@+id/panelDashboard" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:visibility="visible">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp">
                <LinearLayout android:id="@+id/cardVentas" android:layout_width="0dp" android:layout_height="100dp" android:layout_weight="1" android:background="#1a2340" android:gravity="center" android:orientation="vertical" android:layout_marginEnd="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ventas" android:textColor="#4dd0c4" android:textSize="16sp"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/cardProductos" android:layout_width="0dp" android:layout_height="100dp" android:layout_weight="1" android:background="#1a2340" android:gravity="center" android:orientation="vertical" android:layout_marginStart="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Productos" android:textColor="#4dd0c4" android:textSize="16sp"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <LinearLayout android:id="@+id/cardInventario" android:layout_width="0dp" android:layout_height="100dp" android:layout_weight="1" android:background="#1a2340" android:gravity="center" android:orientation="vertical" android:layout_marginEnd="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Inventario" android:textColor="#4dd0c4" android:textSize="16sp"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/cardContador" android:layout_width="0dp" android:layout_height="100dp" android:layout_weight="1" android:background="#1a2340" android:gravity="center" android:orientation="vertical" android:layout_marginStart="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Contador" android:textColor="#4dd0c4" android:textSize="16sp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout android:id="@+id/panelVentas" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:visibility="gone"/>
        <LinearLayout android:id="@+id/panelProductos" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:visibility="gone"/>
        <LinearLayout android:id="@+id/panelInventario" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:visibility="gone"/>
        <LinearLayout android:id="@+id/panelContador" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:visibility="gone"/>
        <LinearLayout android:id="@+id/panelStockReal" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:visibility="gone"/>
        <LinearLayout android:id="@+id/panelChat" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:visibility="gone"/>
    </FrameLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="8dp" android:gravity="center_vertical" android:background="#1a2340">
        <Button android:id="@+id/btnBack" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="← Volver" android:background="#363d52" android:textColor="#e8eaf0" android:padding="8dp"/>
        <TextView android:id="@+id/tvBadge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" android:textColor="#4dd0c4" android:layout_marginStart="12dp"/>
    </LinearLayout>
</LinearLayout>
