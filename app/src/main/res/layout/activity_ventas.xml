<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d1b3e"
    android:orientation="vertical"
    android:padding="16dp">

    <EditText
        android:id="@+id/etBuscar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Buscar producto"
        android:textColor="#e8eaf0"
        android:textColorHint="#5a6278"
        android:background="#363d52"
        android:padding="14dp"
        android:layout_marginBottom="12dp"/>

    <LinearLayout
        android:id="@+id/panelSugerencias"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#1a2340"
        android:padding="8dp"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:id="@+id/panelCarrito"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#1a2340"
        android:padding="8dp"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:id="@+id/panelTotal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="#363d52"
        android:layout_marginBottom="12dp">
        <TextView
            android:id="@+id/tvTotal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Total: 0.00 CUP"
            android:textColor="#4dd0c4"
            android:textSize="18sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnEfectivo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Efectivo"
        android:background="#4dd0c4"
        android:textColor="#1a1f2e"
        android:padding="14dp"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnTransferencia"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Transferencia"
        android:background="#363d52"
        android:textColor="#e8eaf0"
        android:padding="14dp"/>
</LinearLayout>
