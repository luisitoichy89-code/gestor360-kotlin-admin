<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d1b3e"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">
    <TextView android:text="Gestor360°" android:textSize="28sp" android:textStyle="bold" android:textColor="#4dd0c4" android:layout_marginBottom="32dp"/>
    <EditText android:id="@+id/etUsuario" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Usuario" android:textColor="#e8eaf0" android:textColorHint="#5a6278" android:background="#363d52" android:padding="14dp" android:layout_marginBottom="12dp"/>
    <EditText android:id="@+id/etPassword" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Contraseña" android:textColor="#e8eaf0" android:textColorHint="#5a6278" android:background="#363d52" android:padding="14dp" android:layout_marginBottom="24dp" android:inputType="textPassword"/>
    <Button android:id="@+id/btnLogin" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Ingresar" android:textColor="#1a1f2e" android:background="#4dd0c4" android:padding="14dp" android:textStyle="bold"/>
</LinearLayout>
